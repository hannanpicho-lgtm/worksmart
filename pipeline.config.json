{
  "defaultBaseBranch": "main",
  "lockFile": ".pipeline.lock",
  "allowedBranchPrefixes": [
    "feature/",
    "fix/",
    "chore/",
    "docs/",
    "refactor/",
    "release/"
  ],
  "qualityGates": {
    "required": ["npm run format:check", "npm run content:check"],
    "optionalFromNpmScripts": ["lint", "build", "test"]
  },
  "deploy": {
    "enabled": true,
    "mode": "auto",
    "environments": ["auto"],
    "productionUrl": "https://worksmart-188.pages.dev/",
    "verifyContains": ["worksmart0226@gmail.com", "favicon.svg"],
    "verifyFetchAttempts": 3,
    "verifyRetryDelayMs": 5000,
    "pollIntervalMs": 8000,
    "timeoutMs": 300000,
    "skipDuplicateCommitDeploy": true
  },
  "workers": {
    "formAnalytics": {
      "enabled": true,
      "pathPrefix": "workers/form-analytics/",
      "wranglerConfig": "workers/form-analytics/wrangler.toml",
      "verifyHealthUrl": "https://worksmart-form-analytics.hannanpicho.workers.dev/health"
    }
  },
  "github": {
    "autoCreatePr": true,
    "autoMerge": true,
    "mergeMethod": "squash"
  },
  "safety": {
    "requireCleanWorkingTreeAfterCommit": true,
    "blockMainBranchForNonRelease": true
  }
}
