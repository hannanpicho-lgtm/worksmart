{
  "name": "worksmart",
  "private": true,
  "description": "WorkSmart static site (Cloudflare Pages → public/)",
  "scripts": {
    "dev": "npx --yes serve public -l 4173",
    "format": "prettier --write \"**/*.{md,html,css,yml,yaml,json}\"",
    "format:check": "prettier --check \"**/*.{md,html,css,yml,yaml,json}\"",
    "test": "node --test \"tests/**/*.test.mjs\"",
    "content:check": "node scripts/check-content.mjs",
    "pipeline": "node scripts/pipeline.mjs",
    "pipeline:full": "node scripts/pipeline.mjs --auto-merge",
    "pipeline:dry": "node scripts/pipeline.mjs --dry-run",
    "pipeline:release": "node scripts/pipeline.mjs --release --auto-merge",
    "deploy:prod": "node scripts/deploy-pages.mjs --env production",
    "deploy:preview": "node scripts/deploy-pages.mjs --env preview",
    "verify:prod": "node scripts/verify-prod.mjs",
    "worker:form-analytics:deploy": "npx wrangler deploy --config workers/form-analytics/wrangler.toml",
    "ship": "node scripts/ship.mjs",
    "ship:quick": "node scripts/ship.mjs --quick",
    "ship:open": "node scripts/ship.mjs --open"
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
