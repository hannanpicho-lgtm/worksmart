# Optional: Worker root URL for local inject (npm run inject:analytics-endpoint) or set GitHub Actions variable FORM_ANALYTICS_WORKER_URL for CI.
# FORM_ANALYTICS_WORKER_URL=https://worksmart-form-analytics.<account>.workers.dev

# Worker read auth token for /metrics-summary (matches Worker secret).
ANALYTICS_INGEST_SECRET=replace_me
